# BuildShop root-level production defaults
APP_ENV=production
APP_NAME=BuildShop

# Backend runtime
API_HOST=0.0.0.0
API_PORT=8001
SECRET_KEY=change-me-long-random-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TTL_MIN=30
CORS_ORIGINS=https://app.example.com,https://admin.example.com
DATABASE_URL=postgresql+psycopg://buildshop:change-me@db:5432/buildshop

# Frontend runtime
VITE_API_BASE_URL=https://api.example.com
VITE_FEATURE_CHAT=true
VITE_FEATURE_NOTIFICATIONS=true

