# ============================================================
# BuildShop Production Environment Configuration
# ============================================================
# Copy this file to .env and fill in production values
# NEVER commit .env to version control!
# ============================================================

# ============================================================
# CORE APPLICATION SETTINGS
# ============================================================
ENVIRONMENT=production
DEBUG=false
API_HOST=0.0.0.0
API_PORT=8001

# ============================================================
# DATABASE CONFIGURATION
# ============================================================
# For PostgreSQL (recommended for production):
# DATABASE_URL=postgresql://user:password@host:5432/buildshop
# For SQLite (development only):
DATABASE_URL=sqlite:///./app.db

# ============================================================
# JWT & AUTHENTICATION
# ============================================================
# Generate a strong SECRET_KEY with: openssl rand -base64 32
# IMPORTANT: Must be at least 32 characters in production!
SECRET_KEY=your-very-long-random-secret-key-minimum-32-characters-change-this

# JWT settings
JWT_ALGORITHM=HS256  # Use HS256, HS384, HS512, RS256, RS384, or RS512
JWT_ACCESS_TTL_MIN=30  # Access token TTL in minutes
JWT_REFRESH_TTL_MIN=1440  # Refresh token TTL (24 hours)

# Cookie settings
AUTH_COOKIE_NAME=access_token
AUTH_COOKIE_SAMESITE=strict  # Use 'strict' in production (lax/strict/none)
AUTH_COOKIE_SECURE=true  # HTTPS only (true in production)

# ============================================================
# PASSWORD POLICY
# ============================================================
MIN_PASSWORD_LENGTH=12
REQUIRE_SPECIAL_CHAR=true
MAX_LOGIN_ATTEMPTS=5
LOGIN_ATTEMPT_WINDOW_MINUTES=15
SESSION_TIMEOUT_MINUTES=30

# ============================================================
# CORS CONFIGURATION
# ============================================================
# Comma-separated list of allowed origins
CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
# Optional: regex pattern for dynamic origins (e.g., Vercel previews)
# CORS_ORIGIN_REGEX=https://.*\.vercel\.app

# ============================================================
# RATE LIMITING
# ============================================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=100  # General rate limit
RATE_LIMIT_LOGIN_PER_MINUTE=5  # Login attempts
RATE_LIMIT_API_PER_MINUTE=100  # API calls

# ============================================================
# FRONTEND CONFIGURATION
# ============================================================
VITE_API_BASE_URL=https://api.yourdomain.com  # API base URL for frontend

# ============================================================
# SECURITY & LOGGING
# ============================================================
# Structured logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ============================================================
# OPTIONAL: SSL/TLS CERTIFICATES (for self-managed HTTPS)
# ============================================================
# SSL_CERT_PATH=/etc/nginx/ssl/fullchain.pem
# SSL_KEY_PATH=/etc/nginx/ssl/privkey.pem
# DH_PARAM_PATH=/etc/nginx/ssl/dhparam.pem

# ============================================================
# OPTIONAL: EXTERNAL SERVICES
# ============================================================
# Email configuration (for password resets, notifications)
# SMTP_SERVER=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# SMTP_FROM=noreply@yourdomain.com

# Payment gateway (if needed)
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_PUBLIC_KEY=pk_live_...

# ============================================================
# SECURITY CHECKLIST FOR PRODUCTION
# ============================================================
# ✓ Never use development values in production
# ✓ SECRET_KEY must be cryptographically random (min 32 chars)
# ✓ DATABASE_URL must use PostgreSQL in production
# ✓ CORS_ORIGINS must be restricted to your domain(s)
# ✓ DEBUG must be false
# ✓ JWT tokens should be short-lived (30 min recommended)
# ✓ AUTH_COOKIE_SECURE must be true (requires HTTPS)
# ✓ AUTH_COOKIE_SAMESITE must be 'strict' in production
# ✓ Rate limiting should be enabled
# ✓ HTTPS/SSL certificates must be configured
# ✓ Regular security updates and dependency scanning
# ✓ Backup strategies and disaster recovery plan in place
# ✓ Log aggregation and monitoring configured
# ============================================================

